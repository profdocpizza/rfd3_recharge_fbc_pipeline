nextflow.enable.dsl = 2

manifest {
  name = 'rfd3-fbc-binder-design'
  author = 'local'
  description = 'Modular binder design pipeline scaffold'
}

params {
  run_id = "run_${new Date().format('yyyyMMdd_HHmmss')}"
  outdir = "results/${params.run_id}"

  target_pdb = "${projectDir}/inputs/targets/TUBB4B_TUBA1A_hexamer.pdb"
  binder_length = null
  num_designs = null
  design_spec = null
  rfd3_config = "${projectDir}/inputs/configs/rfd3/default.yaml"
  recharge_config = "${projectDir}/inputs/configs/recharge/default.yaml"
  fbc_settings = "${projectDir}/inputs/configs/freebindcraft/run.json"
  fbc_filters = "${projectDir}/inputs/configs/freebindcraft/default_filters.json"
  fbc_advanced = "${projectDir}/inputs/configs/freebindcraft/default_4stage_multimer.json"

  hotspot_sasa_threshold = 0.1
  hotspot_support_dist = 4.0
  hotspot = "A:159 F:106 E:307 D:337"
  hotspot_trimming_residues = ""
  hotspot_trimming_max_residues = null
  hotspot_surface_radius = 25
  hotspot_graph_step = 20

  hotspot_selector_cmd = 'hotspot_selector'
  rfd3_cmd = 'rfd3_run'
  rfd3_max_retries = 20
  rfd3_retry_delay_seconds = 10
  rfd3_skip_existing = true
  protein_recharge_cmd = 'protein_recharge'
  freebindcraft_cmd = 'freebindcraft'
  fbc_max_retries = 20
  fbc_retry_delay_seconds = 10
  fbc_reuse = true
  mutant_zoo_cmd = 'mutant_zoo'

  adapter_script = "${projectDir}/adapters/rfd3_outputs_to_bc_inputs.py"
  manifest_script = "${projectDir}/scripts/make_run_manifest.py"

  container_hotspot = 'ghcr.io/example/hotspot_selector:latest'
  container_rfd3 = 'ghcr.io/example/rfd3:latest'
  container_adapter = 'python:3.11-slim'
  container_recharge = 'ghcr.io/example/proteinrecharge:latest'
  container_fbc = 'ghcr.io/example/freebindcraft:latest'
  container_mutant_zoo = 'ghcr.io/example/mutant_zoo:latest'
  container_aggregate = 'python:3.11-slim'

  max_parallel_designs = 32
  // Optional subset execution: comma-separated step names.
  // Valid: hotspot_trim,rfd3_design,rfd3_to_bc_adapter,protein_recharge,
  //        freebindcraft_filtering,freebindcraft_merge,mutant_zoo,
  //        aggregate_metrics,dashboard_data,run_manifest
  steps = null

  // Optional direct inputs for FBC-only reruns (use with: -entry FBC_ONLY)
  fbc_input_complex = null
  fbc_recharged_sequence = null
  fbc_hotspot_pdb = null

  // Optional direct inputs for adapter->recharge->fbc reruns (use with: -entry ADAPTER_RECHARGE_FBC)
  rerun_rfd3_designs_glob = null
  rerun_target_numbering_map = null
  rerun_hotspot_pdb = null
}

profiles {
  local { includeConfig 'conf/local.config' }
  slurm { includeConfig 'conf/slurm.config' }
  docker { docker.enabled = true; apptainer.enabled = false }
  apptainer { apptainer.enabled = true; docker.enabled = false }
  dev { includeConfig 'conf/dev.config' }
}
